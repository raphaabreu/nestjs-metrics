{
  "compilerOptions": {
    "module": "commonjs",
    "rootDir": "src",
    "sourceMap": true,
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": true,
    "esModuleInterop": true,
    "outDir": "./lib",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
