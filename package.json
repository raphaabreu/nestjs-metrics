{
  "name": "@raphaabreu/nestjs-metrics",
  "version": "1.0.1",
  "description": "Destination-agnostic metric collection and pre-aggregation for NestJS",
  "type": "commonjs",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./cloudwatch": {
      "types": "./lib/cloudwatch/index.d.ts",
      "default": "./lib/cloudwatch/index.js"
    },
    "./console": {
      "types": "./lib/console/index.d.ts",
      "default": "./lib/console/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "cloudwatch": [
        "lib/cloudwatch/index.d.ts"
      ],
      "console": [
        "lib/console/index.d.ts"
      ]
    }
  },
  "scripts": {
    "clean": "rimraf lib",
    "test": "jest",
    "build": "npm run clean && tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "lint": "eslint src/",
    "prepublishOnly": "npm test && npm run lint && publint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphaabreu/nestjs-metrics.git"
  },
  "author": "Raphael Lorenzeto de Abreu <raphael.lorenzeto@gmail.com>",
  "license": "MIT",
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "bugs": {
    "url": "https://github.com/raphaabreu/nestjs-metrics/issues"
  },
  "homepage": "https://github.com/raphaabreu/nestjs-metrics#readme",
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.165.0",
    "@eslint/js": "^9.39.3",
    "@nestjs/common": "*",
    "@nestjs/core": "*",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "publint": "^0.3.18",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^5.0.0",
    "rxjs": "^7.0.0",
    "ts-jest": "^29.0.5",
    "typescript": ">=5.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "@aws-sdk/client-cloudwatch": ">=3.165.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-cloudwatch": {
      "optional": true
    }
  },
  "dependencies": {
    "@raphaabreu/promise-collector": ">=1.0.0"
  }
}
